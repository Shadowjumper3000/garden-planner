# =============================================================================
# Garden Planner — Environment Variables Reference
# Copy to .env and fill in real values before running.
# Lines marked [required] must be set; the application will fail-fast otherwise.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=garden                # postgres user name
POSTGRES_PASSWORD=                  # [required] strong password
POSTGRES_DB=garden                  # database name

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
SERVER_PORT=8080                    # internal container port (default 8080)
JWT_SECRET=                         # [required] random 32+ char string
JWT_EXPIRATION_HOURS=24

# ---------------------------------------------------------------------------
# Domain
# Used in CI (deploy.yml) to derive GF_ROOT_URL and CORS_ALLOW_ORIGINS.
# Set the DOMAIN GitHub secret to just the hostname, e.g. example.com
# ---------------------------------------------------------------------------
DOMAIN=yourdomain.com               # [required in prod] no scheme, no trailing slash
CORS_ALLOW_ORIGINS=https://yourdomain.com  # derived from DOMAIN in CI

# ---------------------------------------------------------------------------
# Admin bootstrap
# On first startup the backend creates this user with the admin role.
# Subsequent restarts are idempotent (role is re-asserted, password not reset).
# ---------------------------------------------------------------------------
ADMIN_EMAIL=                        # [required] e.g. admin@yourdomain.com
ADMIN_PASSWORD=                     # [required] strong password
ADMIN_NAME=Admin                    # display name for the admin account

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=                  # [required]
GF_ROOT_URL=https://yourdomain.com/admin/dashboard  # derived from DOMAIN in CI
# GF_SERVER_SERVE_FROM_SUB_PATH=true is set in docker-compose.base.yml

# Grafana reads the same Postgres instance
GF_DATABASE_HOST=db:5432
GF_DATABASE_NAME=garden
GF_DATABASE_USER=garden
GF_DATABASE_PASSWORD=               # same as POSTGRES_PASSWORD above

# ---------------------------------------------------------------------------
# Docker / Compose
# ---------------------------------------------------------------------------
# External reverse-proxy network name (Traefik / Caddy / nginx-proxy etc.)
PROXY_NETWORK=traefik_proxy

# Image tags pushed to ghcr.io and pulled on the server during deployment
IMAGE_TAG=latest
# Full GHCR image repo prefix, e.g. ghcr.io/your-org/garden-planner
GITHUB_REPOSITORY=owner/garden-planner

# ---------------------------------------------------------------------------
# Development only — NOT used in prod (compose overlay omits these bindings)
# ---------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173
GRAFANA_PORT=3000
DB_PORT=5432